APP_NAME=MarketStat
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Для прода рекомендуется PostgreSQL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/funpaystat
DATABASE_URL=sqlite:///./funpaystat.db

REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=funpaystat
RQ_JOB_TIMEOUT_SECONDS=600

CACHE_TTL_HOURS=24
FUNPAY_LOCALE=en
FUNPAY_REQUEST_TIMEOUT=20
FUNPAY_MAX_RETRIES=5
FUNPAY_BASE_BACKOFF_SECONDS=0.8
FUNPAY_MIN_DELAY_SECONDS=0.25
FUNPAY_JITTER_MIN=0.3
FUNPAY_JITTER_MAX=0.9

LOW_COVERAGE_MIN_MATCHED_OFFERS=25
QUICK_SECTIONS_LIMIT=80
FALLBACK_SECTIONS_LIMIT=120
DEMAND_MAX_SELLERS=40
REVIEW_MAX_PAGES_PER_SELLER=4

# Прокси (через запятую):
DATACENTER_PROXIES=
RESIDENTIAL_PROXIES=
MOBILE_PROXIES=
DDCRM_SERVICE_AUTH_ENABLED=true
DDCRM_SERVICE_AUTH_TOKENS=replace-with-ddcrm-service-token
DDCRM_PROJECT_TOKEN_SIGNING_SALT=replace-with-long-random-project-token-salt
